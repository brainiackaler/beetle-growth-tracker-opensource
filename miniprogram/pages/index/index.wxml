<view class="page">
  <!-- Hero 区域 -->
  <view class="hero">
    <view class="hero-icon">🪲</view>
    <view class="hero-title">甲虫成长记录</view>
    <view class="hero-subtitle">{{statusText}}</view>
    <view class="hero-divider"></view>
  </view>

  <!-- 新增甲虫表单 -->
  <view class="section-title">新增甲虫</view>
  <view class="card form-card">
    <input class="input" placeholder="名称，例如 大力一号" value="{{form.name}}" data-key="name" bindinput="onInput" />
    <input class="input" placeholder="品种，例如 独角仙 / 锹甲" value="{{form.species}}" data-key="species" bindinput="onInput" />
    <picker mode="date" value="{{form.hatchDate}}" bindchange="onDateChange">
      <view class="picker {{form.hatchDate ? '' : 'picker-placeholder'}}">{{form.hatchDate || '🗓️ 孵化或购入日期'}}</view>
    </picker>
    <textarea class="textarea" placeholder="备注，例如 来源、饲养盒、菌瓶信息" value="{{form.notes}}" data-key="notes" bindinput="onInput" />
    <button class="primary-btn" bindtap="createBeetle">✨ 保存甲虫</button>
  </view>

  <!-- 甲虫列表 -->
  <view class="section-title">我的甲虫</view>

  <view wx:if="{{beetles.length === 0}}" class="card">
    <view class="empty-state">
      <view class="empty-icon">🌿</view>
      <view class="empty-text">还没有记录，先添加一只甲虫吧</view>
    </view>
  </view>

  <view wx:for="{{beetles}}" wx:key="id" class="card beetle-card" data-id="{{item.id}}" bindtap="goDetail">
    <view class="beetle-header">
      <view class="beetle-name">{{item.name || '未命名甲虫'}}</view>
      <view class="beetle-arrow">›</view>
    </view>
    <view class="beetle-meta">
      <view wx:if="{{item.species}}" class="meta-tag">
        <text class="meta-icon">🪲</text>
        <text>{{item.species}}</text>
      </view>
      <view wx:if="{{item.hatchDate}}" class="meta-tag">
        <text class="meta-icon">📅</text>
        <text>{{item.hatchDate}}</text>
      </view>
    </view>
    <view wx:if="{{item.notes}}" class="notes">{{item.notes}}</view>
  </view>
</view>
