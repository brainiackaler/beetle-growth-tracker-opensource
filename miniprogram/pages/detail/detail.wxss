/* ========================================
   详情页样式
   ======================================== */

/* --- 甲虫信息头 --- */
.beetle-info {
  position: relative;
}

.beetle-info .title {
  font-size: 42rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 8rpx;
}

.info-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.info-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.info-icon {
  font-size: 22rpx;
}

.detail-actions {
  margin-top: 24rpx;
}

/* --- 记录卡片 --- */
.record-card {
  position: relative;
  overflow: hidden;
}

.record-head {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-date {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.88);
}

.stage {
  padding: 8rpx 18rpx;
  background: rgba(93, 189, 138, 0.18);
  color: rgba(150, 230, 180, 0.9);
  border: 1rpx solid rgba(93, 189, 138, 0.25);
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 不同阶段颜色变体 */
.stage-egg {
  background: rgba(255, 200, 100, 0.15);
  color: rgba(255, 220, 140, 0.9);
  border-color: rgba(255, 200, 100, 0.25);
}

.stage-larva {
  background: rgba(100, 200, 255, 0.15);
  color: rgba(140, 210, 255, 0.9);
  border-color: rgba(100, 200, 255, 0.25);
}

.stage-pupa {
  background: rgba(200, 150, 255, 0.15);
  color: rgba(210, 180, 255, 0.9);
  border-color: rgba(200, 150, 255, 0.25);
}

.stage-adult {
  background: rgba(255, 140, 100, 0.15);
  color: rgba(255, 170, 130, 0.9);
  border-color: rgba(255, 140, 100, 0.25);
}

/* --- 指标网格 --- */
.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 4rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx 18rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.metric-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-bottom: 6rpx;
}

.metric-value {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
}

.metric-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 400;
  margin-left: 4rpx;
}

/* --- 记录操作 --- */
.record-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* --- 图表区域 --- */
.chart-card {
  padding: 24rpx 20rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

/* --- 空状态带图标 --- */
.empty-records {
  text-align: center;
  padding: 50rpx 0;
}

.empty-records .empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-records .empty-text {
  color: rgba(255, 255, 255, 0.35);
  font-size: 26rpx;
}

/* --- Image Grid --- */
.img-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}
.img-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 100%; /* 1:1 Aspect Ratio */
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.img-wrap image {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
}
.img-remove {
  position: absolute;
  top: 8rpx; right: 8rpx;
  width: 36rpx; height: 36rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx;
  z-index: 10;
}
.img-add {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: rgba(255, 255, 255, 0.3);
}
