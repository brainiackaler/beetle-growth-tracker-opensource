<view class="page">
  <!-- 甲虫信息卡 -->
  <view wx:if="{{beetle && !isEditingBeetle}}" class="card beetle-info">
    <view class="title">🪲 {{beetle.name || '未命名甲虫'}}</view>
    <view class="info-meta">
      <view wx:if="{{beetle.species}}" class="info-tag">
        <text class="info-icon">🔬</text>
        <text>{{beetle.species}}</text>
      </view>
      <view wx:if="{{beetle.hatchDate}}" class="info-tag">
        <text class="info-icon">📅</text>
        <text>{{beetle.hatchDate}}</text>
      </view>
    </view>
    <view wx:if="{{beetle.notes}}" class="notes">{{beetle.notes}}</view>
    <view class="button-row detail-actions" style="margin-top: 16px;">
      <button class="primary-btn" bindtap="openEditBeetle" style="min-height:70rpx; font-size:26rpx; line-height: 70rpx;">✏️ 编辑甲虫</button>
      <button class="danger-btn" bindtap="deleteBeetle" style="min-height:70rpx; font-size:26rpx; line-height: 70rpx;">🗑️ 删除甲虫</button>
      <button class="ghost-btn" bindtap="loadAll" style="min-height:70rpx; font-size:26rpx; line-height: 70rpx;">🔄 刷新</button>
    </view>
  </view>

  <!-- 甲虫编辑表单 -->
  <view wx:if="{{beetle && isEditingBeetle}}" class="card form-card">
    <view class="title" style="font-size:32rpx; font-weight:700; margin-bottom:16rpx;">✏️ 编辑甲虫个体</view>
    <input class="input" placeholder="名称，例如 大力一号" value="{{editBeetleForm.name}}" data-key="name" bindinput="onEditBeetleInput" />
    <input class="input" placeholder="品种，例如 独角仙 / 锹甲" value="{{editBeetleForm.species}}" data-key="species" bindinput="onEditBeetleInput" />
    <picker mode="date" value="{{editBeetleForm.hatchDate}}" bindchange="onEditBeetleDateChange">
      <view class="picker {{editBeetleForm.hatchDate ? '' : 'picker-placeholder'}}">🗓️ {{editBeetleForm.hatchDate || '孵化或购入日期'}}</view>
    </picker>
    <textarea class="textarea" placeholder="备注，例如 来源、饲养盒、菌瓶信息" value="{{editBeetleForm.notes}}" data-key="notes" bindinput="onEditBeetleInput" />
    <view class="button-row">
      <button class="primary-btn" bindtap="saveBeetle">💾 保存修改</button>
      <button class="ghost-btn" bindtap="cancelEditBeetle">取消</button>
    </view>
  </view>

  <!-- 成长曲线图表 -->
  <view wx:if="{{records.length >= 2}}" class="section-title">成长曲线</view>
  <growth-chart wx:if="{{records.length >= 2}}" records="{{records}}" />

  <!-- 新增/编辑成长记录表单 -->
  <view class="section-title">{{editingRecordId ? '编辑成长记录' : '新增成长记录'}}</view>
  <view class="card form-card">
    <picker mode="date" value="{{form.recordDate}}" bindchange="onRecordDateChange">
      <view class="picker {{form.recordDate ? '' : 'picker-placeholder'}}">📅 {{form.recordDate || '记录日期'}}</view>
    </picker>
    <picker range="{{stages}}" value="{{stageIndex}}" bindchange="onStageChange">
      <view class="picker">🦋 {{form.stage || '阶段'}}</view>
    </picker>
    <input class="input" type="digit" placeholder="⚖️ 体重 g" value="{{form.weight}}" data-key="weight" bindinput="onInput" />
    <input class="input" type="digit" placeholder="📏 体长 mm" value="{{form.length}}" data-key="length" bindinput="onInput" />
    <input class="input" type="digit" placeholder="🌡️ 温度 ℃" value="{{form.temperature}}" data-key="temperature" bindinput="onInput" />
    <input class="input" type="digit" placeholder="💧 湿度 %" value="{{form.humidity}}" data-key="humidity" bindinput="onInput" />
    <textarea class="textarea" placeholder="📝 备注，例如 换土、蜕皮、进食、异常情况" value="{{form.notes}}" data-key="notes" bindinput="onInput" />
    
    <view class="section-title" style="margin-top:0;">📸 照片</view>
    <view class="img-grid">
      <view class="img-wrap" wx:for="{{selectedImages}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill"></image>
        <view class="img-remove" data-index="{{index}}" bindtap="removeImage">✕</view>
      </view>
      <view class="img-wrap" bindtap="chooseImages" wx:if="{{selectedImages.length < 9}}">
        <view class="img-add">+</view>
      </view>
    </view>

    <view wx:if="{{editingRecordId}}" class="button-row" style="margin-top: 16px;">
      <button class="primary-btn" bindtap="createRecord">💾 保存修改</button>
      <button class="ghost-btn" bindtap="cancelEditRecord">取消</button>
    </view>
    <button wx:else class="primary-btn" bindtap="createRecord" style="margin-top: 16px;">✨ 保存记录</button>
  </view>

  <!-- 历史记录列表 -->
  <view class="section-title">历史记录</view>

  <view wx:if="{{records.length === 0}}" class="card">
    <view class="empty-records">
      <view class="empty-icon">📋</view>
      <view class="empty-text">还没有成长记录</view>
    </view>
  </view>

  <view wx:for="{{records}}" wx:key="id" class="card record-card">
    <view class="record-head">
      <view class="record-date">{{item.recordDate || '未填写日期'}}</view>
      <view class="stage {{item.stageClass || ''}}">{{item.stage || '未填写阶段'}}</view>
    </view>

    <view class="metric-grid">
      <view class="metric-item">
        <view class="metric-label">⚖️ 体重</view>
        <view class="metric-value">{{item.weight || '-'}}<text class="metric-unit"> g</text></view>
      </view>
      <view class="metric-item">
        <view class="metric-label">📏 体长</view>
        <view class="metric-value">{{item.length || '-'}}<text class="metric-unit"> mm</text></view>
      </view>
      <view class="metric-item">
        <view class="metric-label">🌡️ 温度</view>
        <view class="metric-value">{{item.temperature || '-'}}<text class="metric-unit"> ℃</text></view>
      </view>
      <view class="metric-item">
        <view class="metric-label">💧 湿度</view>
        <view class="metric-value">{{item.humidity || '-'}}<text class="metric-unit"> %</text></view>
      </view>
    </view>

    <view wx:if="{{item.notes}}" class="notes">{{item.notes}}</view>

    <view wx:if="{{item.imageUrlsArray && item.imageUrlsArray.length > 0}}" class="img-grid">
      <view class="img-wrap" wx:for="{{item.imageUrlsArray}}" wx:key="*this" wx:for-item="url">
        <image src="{{url}}" mode="aspectFill" data-urls="{{item.imageUrlsArray}}" data-current="{{url}}" bindtap="previewImage"></image>
      </view>
    </view>

    <view class="record-actions" style="gap:16rpx;">
      <button class="small-btn" style="background:rgba(93,189,138,0.2); color:#5dbd8a; border:1rpx solid rgba(93,189,138,0.3);" data-record-id="{{item.id}}" bindtap="editRecord">✏️ 编辑</button>
      <button class="small-btn small-danger-btn" data-record-id="{{item.id}}" bindtap="deleteRecord">🗑️ 删除</button>
    </view>
  </view>
</view>
